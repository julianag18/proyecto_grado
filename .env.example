# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Plantilla de variables de entorno
# COPIA ESTE ARCHIVO COMO ".env" Y RELLENA CON TUS CREDENCIALES REALES
# NUNCA subas el archivo ".env" al repositorio
# ──────────────────────────────────────────────────────────────────────────────

# Ruta absoluta o relativa al archivo JSON de credenciales de tu cuenta de servicio de Firebase
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# Alternativa: pasar el JSON completo como string para despliegues en la nube/CI
FIREBASE_CREDENTIALS_JSON={"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "..."}


# Nombre del usuario que ejecuta migraciones (para trazabilidad)
PAME_USUARIO=admin

# Entorno de ejecución: development | production
ENV=development
