# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Plantilla de variables de entorno
# COPIA ESTE ARCHIVO COMO ".env" Y RELLENA CON TUS CREDENCIALES REALES
# NUNCA subas el archivo ".env" al repositorio
# ──────────────────────────────────────────────────────────────────────────────

# URL de tu proyecto en Supabase (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anon/public de Supabase (Settings → API → anon public)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave service_role (solo para scripts del servidor — NUNCA en el frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Nombre del usuario que ejecuta migraciones (para trazabilidad)
PAME_USUARIO=admin

# Entorno de ejecución: development | production
ENV=development
